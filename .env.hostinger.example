APP_NAME=KarbalaConnect
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://karbalaconnect.in

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=YOUR_HPANEL_DB_NAME
DB_USERNAME=YOUR_HPANEL_DB_USER
DB_PASSWORD=YOUR_HPANEL_DB_PASSWORD

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=file

CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

SANCTUM_STATEFUL_DOMAINS=karbalaconnect.in,www.karbalaconnect.in

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@karbalaconnect.in"
MAIL_FROM_NAME="${APP_NAME}"

CORS_ALLOWED_ORIGINS=*
